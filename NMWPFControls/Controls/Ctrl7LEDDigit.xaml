<UserControl x:Class="NMWPFControls.Controls.Ctrl7LEDDigit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NMWPFControls.Controls"
             mc:Ignorable="d" Focusable="False">
    <UserControl.Resources>
        <FontFamily x:Key="DSEG7Classic">pack://applications:,,,/NMWPFControls;component/Fonts/#DSEG7 Classic</FontFamily>
    </UserControl.Resources>
    <Grid>
        <TextBlock x:Name="LblShadow" Text="8." FontFamily="{StaticResource DSEG7Classic}" FontStyle="Italic" FontWeight="DemiBold"/>
        <TextBlock x:Name="LblDigit" FontFamily="{StaticResource DSEG7Classic}" FontStyle="Italic" FontWeight="DemiBold"/>
    </Grid>
</UserControl>
