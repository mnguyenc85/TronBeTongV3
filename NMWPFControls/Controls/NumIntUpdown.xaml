<UserControl x:Class="NMWPFControls.Controls.NumIntUpdown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" Unloaded="UserControl_Unloaded"
             IsEnabledChanged="UserControl_IsEnabledChanged">
    <Control.Resources>
        <LinearGradientBrush x:Key="NMActiveBorderBrush" StartPoint="0.5,0" EndPoint="0.5,0.1">
            <GradientStop Offset="0" Color="#0000ff"/>
            <GradientStop Offset="1" Color="#b7d9ed"/>
        </LinearGradientBrush>
    </Control.Resources>
    <StackPanel Orientation="Horizontal" Height="22">
        <Label x:Name="lbl1" DockPanel.Dock="Left" Content="" VerticalContentAlignment="Center"/>
        <Border x:Name="border1" BorderThickness="1" BorderBrush="LightGray" Background="White" CornerRadius="2" Height="22">
            <DockPanel x:Name="pnlContent">
                <UniformGrid x:Name="pnlUpDown" Width="20" Rows="2" DockPanel.Dock="Right" Margin="0">
                    <Polygon x:Name="shpUp" Points="8,0 1,7 15,7" Stroke="Black" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="True"
                        MouseDown="shpUp_MouseDown" MouseUp="shpUp_MouseUp" MouseLeave="shpUp_MouseLeave" MouseEnter="shpUp_MouseEnter"/>
                    <Polygon x:Name="shpDown" Points="8,7 1,0 15,0" Stroke="Black" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="True"
                             MouseDown="shpDown_MouseDown" MouseUp="shpDown_MouseUp" MouseEnter="shpDown_MouseEnter" MouseLeave="shpDown_MouseLeave"/>
                </UniformGrid>
                <TextBox x:Name="txtNum" x:FieldModifier="private" Text="0" Padding="2 1" TextChanged="txtNum_TextChanged" VerticalAlignment="Center" BorderThickness="0" LostFocus="txtNum_LostFocus" KeyDown="txtNum_KeyDown" Background="{x:Null}" GotFocus="txtNum_GotFocus"/>
            </DockPanel>
        </Border>
    </StackPanel>
</UserControl>
