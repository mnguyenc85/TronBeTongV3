<UserControl x:Class="NMWPFControls.Controls.NMDateTimeVn"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NMWPFControls.Controls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="local:TextBoxInt">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style x:Key="styleButtonImage" TargetType="Image">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <StackPanel x:Name="pnl1" Background="White" IsEnabledChanged="pnl1_IsEnabledChanged">
        <DockPanel>
            <Button x:Name="btShowCalendar" Click="btShowCalendar_Click" DockPanel.Dock="Right" VerticalAlignment="Stretch" Width="22" Height="20" BorderThickness="1 0 0 0">
                <Image Source="/NMWPFControls;component/Images/calendar-black-32.png" Width="16" Height="16" Style="{StaticResource styleButtonImage}"/>
            </Button>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="3 0 3 0">
                <local:TextBoxInt x:Name="txtDay" Digit="2" ValueChanged="txtDay_ValueChanged"/>
                <TextBlock Text="/"/>
                <local:TextBoxInt x:Name="txtMon" Digit="2" ValueChanged="txtMon_ValueChanged"/>
                <TextBlock Text="/"/>
                <local:TextBoxInt x:Name="txtYear" Digit="4" ValueChanged="txtYear_ValueChanged"/>

                <StackPanel Orientation="Horizontal" x:Name="pnlTime">
                    <TextBlock Text=" "/>
                    <local:TextBoxInt x:Name="txtHour" Digit="2" ValueChanged="txtHour_ValueChanged"/>
                    <TextBlock Text=":"/>
                    <local:TextBoxInt x:Name="txtMin" Digit="2" ValueChanged="txtMin_ValueChanged"/>
                    <StackPanel Orientation="Horizontal" x:Name="pnlSecond">
                        <TextBlock Text=":"/>
                        <local:TextBoxInt x:Name="txtSec" Digit="2" ValueChanged="txtSec_ValueChanged"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </DockPanel>
        <Popup x:Name="Popup1" AllowsTransparency="True" Opened="Popup1_Opened" IsOpen="False">
            <StackPanel>
                <Calendar x:Name="lich1" Language="vi" SelectedDatesChanged="lich1_SelectedDatesChanged" DisplayDateEnd="9999-12-31" DisplayDateStart="2000-01-01"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btToday" Content="Hôm nay" Click="BtToday_Click" Margin="0 0 1 0"/>
                    <Button x:Name="btNow" Content="Hiện tại" Click="BtNow_Click" Grid.Column="1" Margin="1 0 0 0"/>
                </Grid>
            </StackPanel>
        </Popup>
    </StackPanel>
</UserControl>
