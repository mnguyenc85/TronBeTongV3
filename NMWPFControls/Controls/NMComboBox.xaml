<UserControl x:Class="NMWPFControls.Controls.NMComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NMWPFControls.Controls"
             mc:Ignorable="d" >
    <StackPanel x:Name="PnlMain">
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="1" Background="White"
                Padding="2 1" Focusable="False">
            <DockPanel>
                <Button x:Name="BtOpen" Content="⮟" DockPanel.Dock="Right"
                        BorderThickness="0" Background="Transparent" Foreground="Gray" Width="18" FontSize="10"
                        Click="BtOpen_Click" Margin="0 -1 -2 -1"
                        Focusable="False"/>
                <TextBox x:Name="TxtZText" Text="{Binding ZText, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="0" Background="Transparent"
                         PreviewKeyDown="TxtZText_PreviewKeyDown"
                         TextChanged="TxtZText_TextChanged"
                        />
            </DockPanel>
        </Border>
        <Popup x:Name="Popup" AllowsTransparency="True" IsOpen="{Binding ZOpened}" HorizontalAlignment="Stretch"
               MinHeight="24" Focusable="False"
               IsKeyboardFocusWithinChanged="Popup_IsKeyboardFocusWithinChanged">
            <ListView x:Name="LvItems" MinWidth="{Binding ElementName=PnlMain, Path=ActualWidth}"
                      ItemsSource="{Binding ZItemsSource}"
                      SelectedItem="{Binding ZSelectedItem}"
                      ItemTemplate="{Binding ZListItemTemplate}"
                      SelectionMode="Single" 
                      SelectionChanged="LvItems_SelectionChanged"
                      PreviewKeyDown="LvItems_PreviewKeyDown"
                      PreviewMouseLeftButtonUp="LvItems_PreviewMouseLeftButtonUp">
            </ListView>
        </Popup>
    </StackPanel>
</UserControl>
