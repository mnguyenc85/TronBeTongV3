<UserControl x:Class="NMWPFControls.Controls.CtrlMessages"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NMWPFControls.Controls"
             mc:Ignorable="d" 
             Loaded="UserControl_Loaded">
    <Grid>
        <ItemsControl ItemsSource="{Binding Messages}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel VerticalAlignment="Bottom"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="BdrMessage" BorderThickness="1" BorderBrush="LightGray" CornerRadius="3" Margin="3 0 3 3"
                            VerticalAlignment="Bottom" HorizontalAlignment="Right"
                            Background="#d0ffffff" MouseDown="BdrMessage_MouseDown">
                        <StackPanel Margin="3 1">
                            <TextBlock Text="{Binding T, StringFormat={}{0:HH:mm:ss.fff}}" Foreground="Blue" FontSize="10"/>
                            <TextBlock Text="{Binding Text}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
