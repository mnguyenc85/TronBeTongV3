<UserControl x:Class="NMWPFControls.Controls.ToggleSwitch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NMWPFControls.Controls"
             xmlns:mvvm="clr-namespace:NMWPFControls.Core.MVVM"
             mc:Ignorable="d"
             d:DesignWidth="40"
             SnapsToDevicePixels="True" Focusable="True" IsTabStop="True"
             GotFocus="UserControl_GotFocus" LostFocus="UserControl_LostFocus" KeyDown="UserControl_KeyDown"
             IsEnabledChanged="UserControl_IsEnabledChanged">
    <Border x:Name="BdrMain" BorderBrush="Gray" BorderThickness="1" CornerRadius="2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Background="DodgerBlue" Margin="1" CornerRadius="2">
                <TextBlock x:Name="LblTitleOn" Text="{Binding ZOnTitle}" Padding="3 1" Foreground="White" 
                       TextAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Background="#404040" Grid.Column="1" Margin="1" CornerRadius="2">
                <TextBlock x:Name="LblTitleOff" Text="{Binding ZOffTitle}" Padding="3 1" Foreground="WhiteSmoke" 
                       TextAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <Border x:Name="BorderLatchOn" CornerRadius="2" Margin="1" Visibility="{Binding ZOn, Converter={mvvm:BoolToNotVisConverter}}"
                    MouseDown="BorderLatchOn_MouseDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0, 0" EndPoint="0, 1">
                        <GradientStop Color="#e999" Offset="0.0"/>
                        <GradientStop Color="#e888" Offset="0.4"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Rectangle x:Name="FocusRectOn" Stroke="DarkBlue" Margin="1" StrokeDashArray="1" Visibility="Collapsed"/>
            </Border>
            <Border x:Name="BorderLatchOff" CornerRadius="2" Margin="1" Grid.Column="1" Visibility="{Binding ZOn, Converter={mvvm:BoolToVisConverter}}"
                    MouseDown="BorderLatchOff_MouseDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0, 0" EndPoint="0, 1">
                        <GradientStop Color="#e999" Offset="0.0"/>
                        <GradientStop Color="#e888" Offset="0.4"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Rectangle x:Name="FocusRectOff" Stroke="DarkBlue" Margin="1" StrokeDashArray="1" Visibility="Collapsed"/>
            </Border>
        </Grid>            
    </Border>
</UserControl>
