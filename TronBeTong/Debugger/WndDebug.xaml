<Window x:Class="TronBeTongV3.Debugger.WndDebug"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TronBeTongV3.Debugger"
        mc:Ignorable="d"
        Title="Debug" Height="766" Width="800" Background="WhiteSmoke"
        FontFamily="Courier New"
        Loaded="Window_Loaded">
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock x:Name="LblTime" Margin="3 2"/>
            <TextBlock Text="No. observed: "/>
            <TextBlock x:Name="LblObserved"/>
        </StatusBar>
        <StackPanel >
            <Button x:Name="BtUpdate" Content="Update" Margin="3 4 0 3" Click="BtUpdate_Click"/>
            <Button x:Name="BtSetObserver" Content="Select" Margin="3 0 0 3" Click="BtSetObserver_Click"/>
            <Button x:Name="BtCopy" Content="Clipboard" Margin="3 0 0 3" Click="BtCopy_Click"/>
        </StackPanel>
        <DockPanel DockPanel.Dock="Top" Margin="3 3 3 0">
            <Button x:Name="BtClearFilter" Content=" C " Click="BtClearFilter_Click" DockPanel.Dock="Right"/>
            <TextBox x:Name="TxtFilter" Padding="2 1" TextChanged="TxtFilter_TextChanged"/>
        </DockPanel>
        <ListView x:Name="LvTags" Margin="3" ItemsSource="{Binding CVLstVars}"
                  KeyDown="LvTags_KeyDown">
            <ListView.View>
                <GridView>
                    <GridViewColumn DisplayMemberBinding="{Binding STT}" Width="36"/>
                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Ten}" Width="150"/>
                    <GridViewColumn Header="Address" DisplayMemberBinding="{Binding DiaChi}" Width="90"/>
                    <GridViewColumn Header="Value" DisplayMemberBinding="{Binding GiaTri}" Width="90"/>
                    <GridViewColumn Header="Updated Time" DisplayMemberBinding="{Binding TGCapNhat}"/>
                    <GridViewColumn Header="Observe">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding TheoDoi}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
