<Window x:Class="TronBeTongV3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TronBeTongV3"
        xmlns:view="clr-namespace:TronBeTongV3.View"
        xmlns:wpfctrls="clr-namespace:NMWPFControls.Controls;assembly=NMWPFControls"
        mc:Ignorable="d"
        Title="Trạm trộn bê tông" MinWidth="1500" MinHeight="800"
        Loaded="Window_Loaded" Closing="Window_Closing" WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/BootstrapButtons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding AppZoom}" ScaleY="{Binding AppZoom}"/>
        </Grid.LayoutTransform>
        <DockPanel Background="{StaticResource SCADABg01}">
            <!-- Menu -->
            <Menu DockPanel.Dock="Top">
                <Menu.ItemsPanel>
                    <ItemsPanelTemplate>
                        <DockPanel HorizontalAlignment="Stretch"/>
                    </ItemsPanelTemplate>
                </Menu.ItemsPanel>

                <MenuItem Header="Hệ thống" Padding="3 1" Margin="2 1">
                    <MenuItem x:Name="MniSysConfig" Header="Cài đặt..." Click="MniSysConfig_Click"/>
                    <Separator/>
                    <MenuItem x:Name="MniSysExit" Header="Thoát" Click="MniSysExit_Click"/>
                </MenuItem>
                <MenuItem Header="Dữ liệu">
                    <MenuItem Header="Thành phần">
                        <MenuItem x:Name="MniDataAggregates" Header="Cốt liệu..." Click="MniDataAggre_Click"/>
                        <MenuItem x:Name="MniDataCements" Header="Xi măng..." Click="MniDataAggre_Click"/>
                        <MenuItem x:Name="MniDataAdditives" Header="Phụ gia..." Click="MniDataAggre_Click"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="MniDataRecipes" Header="Cấp phối..." Click="MniDataRecipes_Click"/>
                    <Separator/>
                    <MenuItem x:Name="MniDataCustomers" Header="Khách hàng..." Click="MniDataCustomers_Click"/>
                    <MenuItem x:Name="MniDataProjects" Header="Dự án..." Click="MniDataProjects_Click"/>
                    <MenuItem x:Name="MniDataTrucks" Header="Xe..." Click="MniDataTrucks_Click"/>
                </MenuItem>
                <MenuItem x:Name="MnuThongKe" Header="Thống kê" Click="MnuThongKe_Click"/>
                <MenuItem x:Name="MniSetParams" Header="Tham số" Click="MniSetParams_Click"/>
                <MenuItem Header="Giao diện">
                    <MenuItem Header="Zoom">
                        <MenuItem x:Name="MniViewZoom100" Header="100%" Click="MniViewZoom100_Click"/>
                        <MenuItem x:Name="MniViewZoom110" Header="110%" Click="MniViewZoom110_Click"/>
                        <MenuItem x:Name="MniViewZoom120" Header="120%" Click="MniViewZoom120_Click"/>
                        <MenuItem x:Name="MniViewZoom125" Header="125%" Click="MniViewZoom125_Click"/>
                    </MenuItem>
                </MenuItem>
                <MenuItem x:Name="MnuHelp" Header="Hướng dẫn" HorizontalAlignment="Right">
                    <MenuItem x:Name="MniDebug" Header="Debug" Click="MniDebug_Click"/>
                    <MenuItem x:Name="MniDebugInfo" Header="Show info" Click="MniDebugInfo_Click"/>
                    <MenuItem x:Name="MniRegister" Header="Đăng ký" Click="MniRegister_Click"/>
                    <Separator/>
                    <MenuItem x:Name="MniAbout" Header="Thông tin phần mềm" Click="MniAbout_Click"/>
                </MenuItem>
            </Menu>

            <!-- Phieu tron -->
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="3" Background="{StaticResource SCADABg03}" DockPanel.Dock="Right" Width="240" Margin="3">
                <DockPanel>
                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="1" Margin="3 0 3 3" DockPanel.Dock="Bottom">
                        <StackPanel Margin="3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="LblAddr" Margin="2 1" VerticalAlignment="Center"/>
                                <Border x:Name="BdrConn" BorderThickness="1" BorderBrush="Gray" CornerRadius="2" Margin="2" MouseLeftButtonDown="BdrConn_MouseLeftButtonDown">
                                    <TextBlock x:Name="LblConn" Margin="3 1" Text="Khởi tạo"/>
                                </Border>
                                <Border x:Name="BdrPLC" BorderThickness="1" BorderBrush="Gray" CornerRadius="2" Margin="2" MouseLeftButtonDown="BdrConn_MouseLeftButtonDown">
                                    <TextBlock x:Name="LblPLC" Margin="3 1" Text="None"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="LblCycle" VerticalAlignment="Center" Margin="2 1"/>
                                <TextBlock x:Name="LblStatus" Padding="2 1" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblViewCycle" Padding="2 1" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock x:Name="LblDebug"/>
                            </StackPanel>
                            <!--<stackpanel margin="2 1" orientation="horizontal">
                            <textblock text="nhiệt độ: 0" verticalalignment="center" margin="2 1" visibility="collapsed"/>
                            <textblock text="độ ẩm: 0" verticalalignment="center" margin="2 1" visibility="collapsed"/>
                        </stackpanel>-->
                        </StackPanel>
                    </Border>

                    <Border x:Name="PnlServer" BorderBrush="Gray" BorderThickness="1" CornerRadius="1" Margin="3 0 3 3" DockPanel.Dock="Bottom" Background="{StaticResource SCADABg02}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="3">
                                <TextBlock Text="Server: "/>
                                <TextBlock x:Name="LblSrvStatus" Text="Không kết nối"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="3">
                        <view:ViewDonHang x:Name="ViewDonHang" Margin="0 0 0 3"/>

                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="3" Background="{StaticResource SCADABg03}" Margin="0 0 0 3">
                            <StackPanel Margin="3">
                                <TextBlock Text="Phiếu hiện tại" FontWeight="Bold"/>
                                <DockPanel Margin="0 0 0 3">
                                    <TextBlock Text="Số phiếu: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                                    <Border Background="WhiteSmoke" BorderBrush="Gray" BorderThickness="1">
                                        <TextBlock x:Name="LblSoPhieu" Padding="2 1" Text="{Binding ActivePhieu.SoPhieu}"/>
                                    </Border>
                                </DockPanel>
                                <DockPanel Margin="0 0 0 3">
                                    <TextBlock Text="Trạng thái: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                                    <Border Background="WhiteSmoke" BorderBrush="Gray" BorderThickness="1">
                                        <TextBlock x:Name="LblPhieuTT" Padding="2 1" Text="{Binding ActivePhieu.StrTrangThai}"/>
                                    </Border>
                                </DockPanel>
                                <DockPanel Margin="0 0 0 3">
                                    <TextBlock Text="Kẹp chì: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                                    <TextBox x:Name="TxtPhieuSeal" Padding="2 1"/>
                                </DockPanel>
                                <Separator/>
                                <StackPanel x:Name="PnlDocketPrint" Orientation="Horizontal" Margin="0 0 0 3">
                                    <TextBlock Text="Số lần: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                                    <wpfctrls:TextBoxInt x:Name="TxtPrintRepeat" Width="72"/>
                                </StackPanel>
                                <StackPanel>
                                    <Button x:Name="BtInPhieu" Content="In phiếu" Style="{StaticResource BtnSuccess}" Margin="90 0 0 3" Click="BtInPhieu_Click"/>
                                    <CheckBox x:Name="ChkAutoPrint" Content="Tự động in phiếu" Margin="90 0 0 0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="3" Background="{StaticResource SCADABg04}" Margin="0 0 0 3">
                            <StackPanel Margin="3">
                                <TextBlock Text="Cối trộn" FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" Margin="0 0 0 3">
                                    <TextBlock Text="Thời gian trộn: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                                    <wpfctrls:TextBoxDouble x:Name="TxtTGTron" Width="90"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0 0 0 3">
                                    <TextBlock Text="Thời gian xả: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                                    <wpfctrls:TextBoxDouble x:Name="TxtTGXa" Width="90"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0 0 0 3">
                                    <TextBlock Text="Thời gian xả 1/2: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                                    <wpfctrls:TextBoxDouble x:Name="TxtTGXaNua" Width="90"/>
                                </StackPanel>
                                <Button x:Name="BtSetMixerParams" Content="Đặt" Margin="90 0 0 3" Style="{StaticResource BtnInfo}"
                                        Click="BtSetMixerParams_Click"/>
                            </StackPanel>
                        </Border>


                    </StackPanel>
                </DockPanel>
            </Border>

            <DockPanel DockPanel.Dock="Top" MinHeight="640">
                <Grid>
                    <Canvas>
                        <view:GrCtrlKhungXeSkip x:Name="CtrlXeSkip" Canvas.Left="240" Canvas.Top="330" Width="340" Height="270"/>

                        <view:CtrlTPXiMang x:Name="TPXiMang" Canvas.Left="380" Canvas.Top="5" ZNoTP="4"/>

                        <view:CtrlTPCotLieu2 x:Name="TPCotLieu" Canvas.Left="15" Canvas.Top="280" ZSoTP="3"/>

                        <view:CtrlTPNuoc x:Name="TPNuoc" Canvas.Left="780" Canvas.Top="10"/>

                        <view:CtrlTPPhuGia x:Name="TPPhuGia" ZNoTP="2" Canvas.Left="60" Canvas.Top="10"/>

                        <view:CtrlTPBangTai x:Name="TPBangTai" Canvas.Left="10" Canvas.Top="520" Visibility="Collapsed"/>

                        <view:CtrlMixer x:Name="CtrlMixer1" Canvas.Left="460" Canvas.Top="400"/>
                        
                        <view:CtrlMidBin x:Name="CtrlThungCLTG" Canvas.Left="640" Canvas.Top="330" ZFill="#a0f5b04f" Visibility="Collapsed"/>
                    </Canvas>

                    <Border x:Name="PnlDebug" BorderBrush="Gray" BorderThickness="1" CornerRadius="1" Background="{StaticResource RAL_7032_7035}"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="3 3 3 0">
                        <StackPanel Margin="3">
                            <TextBlock Text="Debug"/>
                            <Button x:Name="BtDebuggerConfig" Content="Config" Style="{StaticResource PLCBtnInfo}" Click="BtDebuggerConfig_Click"/>
                            <Button x:Name="BtDebuggerExport" Content="Export" Style="{StaticResource PLCBtnInfo}" Click="BtDebuggerExport_Click"/>
                            <Button x:Name="BtDebuggerStart" Content="Start" Style="{StaticResource PLCBtnWarn}" Click="BtDebuggerStart_Click"/>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="3" Background="{StaticResource RAL7035}"
                        Height="360" Width="135" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="3 3 3 0">
                        <StackPanel Margin="6">
                            <wpfctrls:ToggleSwitch ZOnTitle="Auto" ZOffTitle="Manual" FontSize="16" Width="186" HorizontalAlignment="Left" Visibility="Collapsed"/>
                            <StackPanel Margin="0 3 0 0">
                                <Button x:Name="BtRun" Content="Bắt đầu trộn" Style="{StaticResource BtnSuccess}" FontSize="16"
                                    Click="BtRun_Click"/>
                                <Button x:Name="BtStop" Content="Dừng trộn" Style="{StaticResource BtnWarning}" FontSize="16" Margin="0 3 0 0"
                                    Click="BtStop_Click"/>
                                <Button x:Name="BtReset" Content="Reset" Style="{StaticResource BtnPrimary}" FontSize="16" Margin="0 3 0 0"
                                    Click="BtReset_Click"
                                    PreviewMouseLeftButtonDown="BtReset_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="BtReset_PreviewMouseLeftButtonUp"/>
                                <Button x:Name="BtSimulation" Content="Chạy mô phỏng" Style="{StaticResource BtnInfo}" FontSize="16" Margin="0 3 0 0"
                                    Click="BtSimulation_Click"/>
                            </StackPanel>

                            <Separator Margin="0 6 0 3"/>
                            <DockPanel Margin="0 0 0 3">
                                <TextBlock Text="Số khối" Width="48" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtTheTich" Text="0" Margin="2 1" IsReadOnly="True" Background="WhiteSmoke"/>
                            </DockPanel>
                            <DockPanel Margin="0 0 0 3">
                                <TextBlock Text="Số mẻ" Width="48" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtSoMe" Text="0" Margin="2 1" IsReadOnly="True" Background="WhiteSmoke"/>
                            </DockPanel>

                            <wpfctrls:CtrlLEDIndicator x:Name="LEDRunning" Height="20" OnColor="Lime" Title="Đang chạy" FontSize="14"/>
                            <wpfctrls:CtrlLEDIndicator x:Name="LEDMixStarted" Height="20" OnColor="Orange" Title="Nạp nguyên liệu" FontSize="14" Margin="0 3 0 0" Visibility="Collapsed"/>
                            <wpfctrls:CtrlLEDIndicator x:Name="LEDMixCompleleted" Height="20" OnColor="OrangeRed" Title="Trộn xong" FontSize="14" Margin="0 3 0 0" Visibility="Collapsed"/>
                            <wpfctrls:CtrlLEDIndicator x:Name="LEDSimulation" Height="20" OnColor="DodgerBlue" Title="Mô phỏng" FontSize="14" Margin="0 3 0 0"/>

                            <Separator Margin="0 3"/>
                            <wpfctrls:CtrlLEDIndicator x:Name="LEDWeightMode" Height="20" OnColor="Lime" Title="Cân tay" FontSize="14"/>
                            <wpfctrls:CtrlLEDIndicator x:Name="LEDCementDischargeMode" Height="20" OnColor="Lime" Title="Xả tay" FontSize="14" Margin="0 3 0 0"/>
                            <wpfctrls:CtrlLEDIndicator x:Name="LEDConcreteDischargeMode" Height="20" OnColor="Lime" Title="Xả bê tông tay" FontSize="14" Margin="0 3 0 0"/>
                            <wpfctrls:CtrlLEDIndicator x:Name="LEDSkipMode" Height="20" OnColor="Lime" Title="Xe Skip" FontSize="14" Margin="0 3 0 0"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </DockPanel>

            <DockPanel DockPanel.Dock="Bottom" Margin="3 3 0 3">
                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="1" Background="{StaticResource SCADABg03}">
                    <StackPanel>
                        <Button x:Name="BtOrderCreate" Content="Tạo đơn mới" Style="{StaticResource BtnPrimary}" Margin="3"
                            Click="BtOrderCreate_Click"/>
                        <TextBlock Text="Lọc đơn hàng" Margin="3 0"/>
                        <TextBox x:Name="TxtDonHangFilter" Margin="3 0 3 3" Width="120" Padding="2 1" TextChanged="TxtDonHangFilter_TextChanged" ToolTip="Lọc đơn hàng"/>
                        <StackPanel Orientation="Horizontal" Margin="3 0 3 3">
                            <Button x:Name="BtClearActiveDon" Content="Xóa" Width="58" Margin="0 0 2 0" Command="{Binding CmdClearOnlineOrder}"/>
                            <Button x:Name="BtMarkActiveDon" Content="Chọn" Width="58" Margin="2 0 0 0" Click="BtMarkActiveDon_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <ListView x:Name="LvDonHang" 
                  ItemsSource="{Binding CVDsDonOnline}"
                  SelectionChanged="LvDonHang_SelectionChanged"
                  PreviewMouseRightButtonDown="LvDonHang_PreviewMouseRightButtonDown">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="STT" DisplayMemberBinding="{Binding STT}"/>
                            <GridViewColumn Header="Trạng thái " Width="72">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value=""/>
                                                    <Setter Property="Foreground" Value="Black"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TrangThai}" Value="1">
                                                            <Setter Property="Foreground" Value="#4040ff"/>
                                                            <Setter Property="Text" Value="Đang chọn"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TrangThai}" Value="2">
                                                            <Setter Property="Foreground" Value="LimeGreen"/>
                                                            <Setter Property="Text" Value="Đang trộn"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Mã" DisplayMemberBinding="{Binding Ma}"/>
                            <GridViewColumn Header="Khách hàng" DisplayMemberBinding="{Binding KhachHang.Ten}"/>
                            <GridViewColumn Header="Dự án">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DuAn.DuAn}"/>
                                            <TextBlock Text="-"/>
                                            <TextBlock Text="{Binding DuAn.CongTrinh}"/>
                                            <TextBlock Text="-"/>
                                            <TextBlock Text="{Binding DuAn.HangMuc}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Thể tích đặt (m3)" DisplayMemberBinding="{Binding TheTichDH}"/>
                            <GridViewColumn Header="Thể tích tích lũy (m3)">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TheTichHT}" FontWeight="Bold"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Tổng phiếu" DisplayMemberBinding="{Binding TongSoPhieu}"/>
                            <GridViewColumn Header="Tổng mẻ" DisplayMemberBinding="{Binding MeHT}"/>
                            <GridViewColumn Header="KL tích lũy (kg)" DisplayMemberBinding="{Binding KLHT}"/>
                            <GridViewColumn Header="">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="BtViewDonHang" Content="Xem" Style="{StaticResource BtnPrimary}"
                                                    Padding="3 0" FontSize="10"
                                                    Click="BtViewDonHang_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </DockPanel>

        <wpfctrls:CtrlMessages x:Name="DebugMsg1" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
    </Grid>
</Window>
