<Window x:Class="TronBeTongV3.View.WndEditKhachHang"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TronBeTongV3.View"
        mc:Ignorable="d"
        Title="Thông tin khách hàng" Height="640" Width="900" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Colors.xaml"/>
                <ResourceDictionary Source="../Styles/BootstrapButtons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding AppZoom}" ScaleY="{Binding AppZoom}"/>
        </Grid.LayoutTransform>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="3"/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>
        <GridSplitter Grid.Column="1"/>

        <Border BorderThickness="1" BorderBrush="Gray" CornerRadius="3" Background="{StaticResource SCADABg04}" Margin="3 3 0 3">
            <DockPanel Margin="3">
                <TextBox x:Name="TxtFilter" DockPanel.Dock="Top" Padding="2 1"
                         TextChanged="TxtFilter_TextChanged"/>
                <ListView x:Name="LvKhachHang" ItemsSource="{Binding Ds.CVDsKH}" SelectionChanged="LvKhachHang_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="STT" DisplayMemberBinding="{Binding STT}"/>
                            <GridViewColumn Header="Mã" DisplayMemberBinding="{Binding Ma}"/>
                            <GridViewColumn Header="Tên" DisplayMemberBinding="{Binding Ten}"/>
                            <GridViewColumn Header="SĐT" DisplayMemberBinding="{Binding Sdt}"/>
                            <GridViewColumn Header="Liên hệ" DisplayMemberBinding="{Binding LienHe}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" BorderThickness="1" BorderBrush="Gray" CornerRadius="3" Background="{StaticResource SCADABg04}" Margin="0 3 3 3">
            <StackPanel Grid.Column="2" Margin="3">
                <TextBlock x:Name="LblKHTitle" FontWeight="Bold" Foreground="SteelBlue" FontSize="14"/>
                <TextBlock Text="* Mã:"/>
                <TextBox Padding="2 1" Text="{Binding CurKH.Ma}"/>
                <TextBlock Text="* Tên khách hàng:" Margin="0 3 0 0"/>
                <TextBox Padding="2 1" Text="{Binding CurKH.Ten}"/>
                <TextBlock Text="Địa chỉ:" Margin="0 3 0 0"/>
                <TextBox Padding="2 1" Text="{Binding CurKH.DiaChi}"/>
                <TextBlock Text="Điện thoại:" Margin="0 3 0 0"/>
                <TextBox Padding="2 1" Text="{Binding CurKH.Sdt}"/>
                <TextBlock Text="Email:" Margin="0 3 0 0"/>
                <TextBox Padding="2 1" Text="{Binding CurKH.Email}"/>
                <TextBlock Text="Mã số thuế:" Margin="0 3 0 0"/>
                <TextBox Padding="2 1" Text="{Binding CurKH.MaSoThue}"/>
                <TextBlock Text="Người liên hệ:" Margin="0 3 0 0"/>
                <TextBox Padding="2 1" Text="{Binding CurKH.LienHe}"/>
                <TextBlock Text="Ghi chú:" Margin="0 3 0 0"/>
                <TextBox Padding="2 1" Height="48" Text="{Binding CurKH.GhiChu}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 6 0 0">
                    <Button x:Name="BtClone" Content="Bản sao" Style="{StaticResource BtnPrimary}" Width="72"
                            Click="BtClone_Click"/>
                    <Button x:Name="BtNew" Content="Mới" Style="{StaticResource BtnPrimary}" Width="72" Margin="6 0 0 0"
                            Click="BtNew_Click"/>
                    <Button Content="Lưu" Style="{StaticResource BtnSuccess}" Width="72" Margin="6 0 0 0"
                            Command="{Binding CmdSave}"/>
                </StackPanel>
                <Button x:Name="BtSelect" Content="Chọn" Margin="0 6 0 0" Style="{StaticResource BtnPrimary}" IsEnabled="False"
                        Click="BtSelect_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 6 0 0">
                    <Button x:Name="BtImportCsv" Content="Import .csv" Style="{StaticResource BtnInfo}" Width="72"
                            Click="BtImportCsv_Click"/>
                    <Button x:Name="BtExportCsv" Content="Export .csv" Style="{StaticResource BtnInfo}" Width="72" Margin="6 0 0 0"
                            Click="BtExportCsv_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</Window>
