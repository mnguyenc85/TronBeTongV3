<Window x:Class="TronBeTongV3.View.WndEnterPass"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TronBeTongV3.View"
        mc:Ignorable="d" Title="Nhập password" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Colors.xaml"/>
                <ResourceDictionary Source="../Styles/BootstrapButtons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Background="WhiteSmoke">
        <StackPanel Margin="6">
            <PasswordBox x:Name="TxtPass" Margin="0 0 0 6" Width="150" Padding="2"
                         KeyDown="TxtPass_PreviewKeyDown"/>
            <Button x:Name="BtAccept" Content="Ok" Style="{StaticResource BtnPrimary}" Click="BtAccept_Click"/>
        </StackPanel>
    </Grid>
</Window>
