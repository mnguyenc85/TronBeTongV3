<Window x:Class="TronBeTongV3.View.WndEditRecipe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TronBeTongV3.View"
        xmlns:nmwpfctrl="clr-namespace:NMWPFControls.Controls;assembly=NMWPFControls"
        mc:Ignorable="d"
        Title="Công thức bê tông" Height="720" Width="1366" Background="WhiteSmoke" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Colors.xaml"/>
                <ResourceDictionary Source="../Styles/BootstrapButtons.xaml"/>
                <ResourceDictionary Source="../Styles/ListViewStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <DockPanel>
        <DockPanel.LayoutTransform>
            <ScaleTransform ScaleX="{Binding AppZoom}" ScaleY="{Binding AppZoom}"/>
        </DockPanel.LayoutTransform>
        
        <Border DockPanel.Dock="Right" Margin="0 3 3 3" BorderBrush="Gray" BorderThickness="1" CornerRadius="3" Background="{StaticResource SCADABg04}">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top">
                    <StackPanel DockPanel.Dock="Right" Margin="3 6 3 3">
                        <Button x:Name="BtCTSave" Content="Lưu" Width="120" Style="{StaticResource BtnSuccess}"
                            Click="BtCTSave_Click"/>
                        <Button x:Name="BTCTNew" Content="Mới" Width="120" Style="{StaticResource BtnPrimary}" Margin="0 3 0 0"
                            Click="BTCTNew_Click"/>
                        <Button x:Name="BTCTDelete" Content="Xóa" Width="120" Style="{StaticResource BtnDanger}" Margin="0 3 0 0"
                            Click="BTCTDelete_Click"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Top" Margin="3 6 3 3" >
                        <StackPanel Orientation="Horizontal" Margin="0">
                            <TextBlock Text="*Mã: " TextAlignment="Right" VerticalAlignment="Center" Width="90"/>
                            <TextBox Width="240" Padding="2 1" Text="{Binding CurCT.Ma}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 3 0 0">
                            <TextBlock Text="Mác bê tông: " TextAlignment="Right" VerticalAlignment="Center" Width="90"/>
                            <TextBox Width="120" Padding="2 1" Text="{Binding CurCT.Mac}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 3 0 0">
                            <TextBlock Text="Độ sụt (mm): " TextAlignment="Right" VerticalAlignment="Center" Width="90"/>
                            <TextBox x:Name="TxtSlump" Width="120" Padding="2 1" Text="{Binding CurCT.Slump}"/>
                            <Button x:Name="BtAddAppx" Content="±" Width="20" Click="BtAddAppx_Click"/>
                            <TextBlock Text="Aggr. Max: " TextAlignment="Right" VerticalAlignment="Center" Width="90"/>
                            <TextBox Width="90" Padding="2 1" Text="{Binding CurCT.KTHat}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 3 0 0">
                            <TextBlock Text="Tỷ lệ w/c: " TextAlignment="Right" VerticalAlignment="Center" Width="90"/>
                            <TextBox Width="90" Padding="2 1" IsReadOnly="True" Text="{Binding CurCT.WCRatio}"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>

                <Grid Margin="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Thành phần: " TextAlignment="Right" HorizontalAlignment="Left" VerticalAlignment="Center" Width="90" FontWeight="Bold"/>
                        <!--<StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0 3 0 0" Height="20">
                        <TextBlock Text="KL Nước (kg): " TextAlignment="Right" VerticalAlignment="Center" Width="90"/>
                        <nmwpfctrl:TextBoxDouble Width="90" x:Name="TxtKLNuoc" Padding="2 1" Text="{Binding CurCT.KLNuoc}" ValueChanged="TxtKLNuoc_ValueChanged"/>
                    </StackPanel>-->
                        <DockPanel DockPanel.Dock="Bottom" Margin="0 3 0 0">
                            <Button x:Name="BtTP4Silos" Content="Theo silo" Style="{StaticResource BtnPrimary}" Width="60"
                                Click="BtTP4Silos_Click"/>
                            <Button x:Name="BtTPKiemTra" Content="Kiểm tra" Style="{StaticResource BtnSuccess}" Width="60" Margin="6 0 0 0"
                                Click="BtTPKiemTra_Click"/>
                            <Button x:Name="BtTPXoa" Content="Xóa" Style="{StaticResource BtnDanger}" Width="48" Margin="6 0 0 0" DockPanel.Dock="Right"
                                Click="BtTPXoa_Click"/>
                            <Button x:Name="BtTPHuyXoa" Content="Hủy" Style="{StaticResource BtnWarning}" Width="48" Margin="6 0 0 0" DockPanel.Dock="Right"
                                Click="BtTPHuyXoa_Click"/>
                            <StackPanel/>
                        </DockPanel>

                        <StackPanel DockPanel.Dock="Bottom">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Tổng KL: " Width="54" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblTongKL" Text="0" FontWeight="Bold" Padding="3 1" Width="60" TextAlignment="Right"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="KL Đặt" Width="54" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtTongKLDat" Width="60" Text="2400" TextAlignment="Right" TextChanged="TxtTongKLDat_TextChanged"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="KL Bù" Width="54" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblKLBu" Text="0" Padding="3 1" Width="60" TextAlignment="Right"/>
                            </StackPanel>
                        </StackPanel>
                        <ListView x:Name="LvTP" Margin="0 3 0 0" ItemsSource="{Binding CurCT.DsThanhPhan}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="STT" DisplayMemberBinding="{Binding STT}"/>
                                    <GridViewColumn Header="Mã">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding NL.Ma}" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="Black"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding NL.PhanLoai}" Value="1">
                                                                    <Setter Property="Foreground" Value="#4040ff"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding NL.PhanLoai}" Value="2">
                                                                    <Setter Property="Foreground" Value="#afaf00"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding NL.PhanLoai}" Value="3">
                                                                    <Setter Property="Foreground" Value="#ff0010"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding NL.PhanLoai}" Value="4">
                                                                    <Setter Property="Foreground" Value="DeepSkyBlue"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="KL (kg)">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <nmwpfctrl:TextBoxDouble x:Name="TxtTPKL" Text="{Binding KL}" Width="72"
                                                                     PreviewKeyDown="TxtTPKL_PreviewKeyDown" ValueChanged="TxtTPKL_ValueChanged"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Kiểm tra" DisplayMemberBinding="{Binding SiloTen}" Width="90"/>
                                    <GridViewColumn Header="TT ">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value=""/>
                                                            <Setter Property="Foreground" Value="Black"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}" Value="1">
                                                                    <DataTrigger.Setters>
                                                                        <Setter Property="Text" Value="+"/>
                                                                        <Setter Property="Foreground" Value="Green"/>
                                                                    </DataTrigger.Setters>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="3">
                                                                    <DataTrigger.Setters>
                                                                        <Setter Property="Text" Value="-"/>
                                                                        <Setter Property="Foreground" Value="Red"/>
                                                                    </DataTrigger.Setters>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Left">
                    </StackPanel>

                    <DockPanel Grid.Column="2" Grid.Row="1">
                        <TextBlock DockPanel.Dock="Top"/>
                        <TextBox x:Name="TxtNLFilter" DockPanel.Dock="Top" Padding="2 1" Margin="0 3 0 2" Height="21" TextChanged="TxtNLFilter_TextChanged"/>
                        <ListView ItemsSource="{Binding CVDsNL}" SelectedItem="{Binding SelectedNL}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="STT" DisplayMemberBinding="{Binding STT}"/>
                                    <GridViewColumn Header="Mã" DisplayMemberBinding="{Binding Ma}"/>
                                    <GridViewColumn Header="Tên" DisplayMemberBinding="{Binding Ten}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>

                    <StackPanel Grid.Column="1" Grid.Row="1" VerticalAlignment="Center" Margin="3 0">
                        <Button x:Name="BtAddNL" Content="&lt;" Click="BtAddNL_Click" Style="{StaticResource BtnPrimary}"/>
                    </StackPanel>
                </Grid>
            </DockPanel>
        </Border>

        <ListView x:Name="LvCongThuc" Margin="3 3 0 3" AlternationCount="2" ItemContainerStyle="{StaticResource ListViewItemStyle1}"
                  ItemsSource="{Binding DsCongThuc}"
                  SelectionChanged="LvCongThuc_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="STT" DisplayMemberBinding="{Binding STT}"/>
                    <GridViewColumn Header="Mã" DisplayMemberBinding="{Binding Ma}"/>
                    <GridViewColumn Header="Mác" DisplayMemberBinding="{Binding Mac}"/>
                </GridView>
            </ListView.View>
        </ListView>
        
    </DockPanel>
</Window>
