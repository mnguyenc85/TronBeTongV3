<Window x:Class="TronBeTongV3.View.WndRegister"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TronBeTongV3.View"
        mc:Ignorable="d"
        Title="Đăng ký phần mềm" Background="WhiteSmoke"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/BootstrapButtons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <StackPanel>
        <DockPanel Margin="6">
            <TextBlock Text="Mã máy:" VerticalAlignment="Center" Width="60"/>
            <TextBox x:Name="TxtMaPC" IsReadOnly="True" Width="320" Padding="2 1"/>
        </DockPanel>
        <DockPanel Margin="6 0 6 6">
            <TextBlock Text="Mã PLC:" VerticalAlignment="Center" Width="60"/>
            <TextBox x:Name="TxtMaPLC" IsReadOnly="True" Width="320" Padding="2 1"/>
        </DockPanel>
        <DockPanel Margin="6 0 6 6">
            <TextBlock Text="Serial:" VerticalAlignment="Center" Width="60"/>
            <TextBox x:Name="TxtSerial" IsReadOnly="True" Width="320" Padding="2 1"/>
        </DockPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="6 0 6 6">
            <Button Content="Đăng ký" Width="90" Style="{StaticResource BtnPrimary}"/>
        </StackPanel>
    </StackPanel>
</Window>
