<Window x:Class="TronBeTongV3.View.WndConfig"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TronBeTongV3.View"
        mc:Ignorable="d"
        Title="Cài đặt hệ thống" Height="360" Width="640"
        Background="WhiteSmoke" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/BootstrapButtons.xaml"/>
                <ResourceDictionary Source="../Styles/TabControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>        
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="3" HorizontalAlignment="Right">
            <Button x:Name="BtAccept" Content="Lưu" Width="90" Style="{StaticResource BtnPrimary}" FontSize="14" Click="BtAccept_Click"/>
        </StackPanel>

        <TabControl x:Name="TabMain" Margin="3" TabStripPlacement="Left" Style="{StaticResource FlatRightTabCtrlStyle}">
            <TabItem x:Name="TabItemCSDL" Header="CSDL" Style="{StaticResource FlatRightTabItemStyle}" BorderBrush="DodgerBlue"
                     FontSize="14">
                <DockPanel Background="#fdfdfd">
                    <StackPanel Background="WhiteSmoke" Margin="3">
                        <StackPanel Orientation="Horizontal" Margin="12 6 3 0">
                            <TextBlock Text="CSDL" Width="60" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CboDbSrcs" Width="240"
                                      ItemsSource="{Binding DbSrcs}" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                            <Button x:Name="BtTestConn" Content="Thử kết nối" Margin="3 0 0 0" Style="{StaticResource BtnSuccess}"
                                    Click="BtTestConn_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="12 6 3 0">
                            <TextBlock Text="Size" Width="60" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtDbSize" Width="120" Padding="2 1"/>
                            <TextBlock Text=" Mb" Width="60" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="12 6 3 0">
                            <TextBlock Text="Log" Width="60" VerticalAlignment="Center"/>
                            <Button x:Name="BtDelLog" Content="Xóa log" Margin="3 0 0 0" Style="{StaticResource BtnDanger}"
                                    Click="BtDelLog_Click"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </TabItem>
            <TabItem x:Name="TabItemPLC" Header="PLC" Style="{StaticResource FlatRightTabItemStyle}" BorderBrush="DodgerBlue" FontSize="14">
                <DockPanel Background="#fdfdfd">
                    <StackPanel Background="WhiteSmoke" Margin="3">
                        <RadioButton x:Name="OptS71200Ethernet" Content="S7-1200 - Mạng" Margin="6 3 3 3" FontWeight="Bold" IsChecked="True"/>
                        <Separator/>
                        <StackPanel Margin="6 3 3 6">
                            <DockPanel Margin="12 0 0 6">
                                <TextBlock Text="Network Interface:" Width="120"/>
                                <ComboBox x:Name="CboNetInterface" ItemsSource="{Binding Networks}" DisplayMemberPath="Name"
                                      SelectionChanged="CboNetInterface_SelectionChanged"/>
                            </DockPanel>
                            <StackPanel Orientation="Horizontal" Margin="12 0 0 6">
                                <TextBlock Text="Local IP Address:" Width="120"/>
                                <TextBox x:Name="TxtLocalIp" Padding="2 1" Width="240"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="12 0 0 6">
                                <TextBlock Text="PLC Address" Width="120" VerticalAlignment="Center" FontSize="14"/>
                                <TextBox x:Name="TxtPLCAddr" Width="240" FontSize="14" Padding="2 1"/>
                            </StackPanel>
                            <Button x:Name="BtPlcExportTags" Content="Export Tags" Width="90" HorizontalAlignment="Left" Margin="132 0 3 6" Style="{StaticResource BtnInfo}"
                                Click="BtPlcExportTags_Click"/>
                        </StackPanel>

                        <RadioButton x:Name="OptS7200KEPServer" Content="S7-200 - KEPServer" Margin="6 6 3 3" FontWeight="Bold"/>
                        <Separator/>
                        <StackPanel Margin="6 3 3 6">
                            <StackPanel Orientation="Horizontal" Margin="12 0 3 3">
                                <TextBlock Text="Channel.Device" Width="120" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtKSrvPath" Width="240" FontSize="14" Padding="2 1"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </TabItem>
            <TabItem x:Name="TabItemPhieu" Header="Phiếu" Style="{StaticResource FlatRightTabItemStyle}" BorderBrush="DodgerBlue" FontSize="14">
                <DockPanel Background="#fdfdfd">
                    <StackPanel Background="WhiteSmoke" Margin="3">
                        <TextBlock Text="Mẫu phiếu" Margin="6 0 3 6" FontWeight="Bold"/>
                        <ComboBox x:Name="CboMauPhieu" Margin="12 0 3 6"/>
                        <TextBlock Text="Mẫu phiếu chi tiết" Margin="6 0 3 6" FontWeight="Bold"/>
                        <ComboBox x:Name="CboMauPhieuChiTiet" Margin="12 0 3 6"/>

                        <TextBlock Text="Thông tin trạm trộn" Margin="6 0 3 6" FontWeight="Bold"/>
                        <DockPanel Margin="12 0 3 6">
                            <TextBlock Text="Tên" Width="72" VerticalAlignment="Center" FontSize="14"/>
                            <TextBox x:Name="TxtCTyTen" FontSize="14" Padding="2 1"/>
                        </DockPanel>
                        <DockPanel Margin="12 0 3 6">
                            <TextBlock Text="Địa chỉ" Width="72" VerticalAlignment="Center" FontSize="14"/>
                            <TextBox x:Name="TxtCTyDiaChi" FontSize="14" Padding="2 1"/>
                        </DockPanel>
                        <DockPanel Margin="12 0 3 6">
                            <TextBlock Text="SĐT 1" Width="72" VerticalAlignment="Center" FontSize="14"/>
                            <TextBox x:Name="TxtCTySDT1" FontSize="14" Padding="2 1"/>
                        </DockPanel>
                        <DockPanel Margin="12 0 3 6">
                            <TextBlock Text="SĐT 2" Width="72" VerticalAlignment="Center" FontSize="14"/>
                            <TextBox x:Name="TxtCTySDT2" FontSize="14" Padding="2 1"/>
                        </DockPanel>
                        <DockPanel Margin="12 0 3 6" Visibility="Collapsed">
                            <DockPanel DockPanel.Dock="Top">
                                <TextBlock Text="Logo" Width="72" VerticalAlignment="Center" FontSize="14"/>
                                <TextBox x:Name="TxtLogoPath" FontSize="14" Padding="2 1" PreviewKeyDown="TxtLogoPath_PreviewKeyDown"/>
                            </DockPanel>
                            <Image x:Name="ImgLogo" Height="64" Margin="72 0 0 0"/>
                        </DockPanel>

                        <StackPanel x:Name="PnlAutoPrint" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Margin="6 0 3 6">
                                <CheckBox x:Name="ChkAutoPrint" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="Tự động in" FontWeight="Bold" Margin="6 0 0 0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="12 0 3 6">
                                <TextBlock Text="Số lần in:" Width="72" VerticalAlignment="Center" FontSize="14"/>
                                <TextBox x:Name="TxtPrintTimes" Width="72"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </TabItem>
            
            <TabItem x:Name="TabItemThongKe" Header="Thống kê" Style="{StaticResource FlatRightTabItemStyle}" BorderBrush="DodgerBlue" FontSize="14">
                <DockPanel Background="#fdfdfd">
                    <StackPanel Background="WhiteSmoke" Margin="3">
                        <TextBlock Text="Mẫu thống kê" Margin="6 0 3 6" FontWeight="Bold"/>
                        <ComboBox x:Name="CboMauThongKe" Margin="12 0 3 6"/>
                        <TextBlock Text="Mẫu thống kê chi tiết" Margin="6 0 3 6" FontWeight="Bold"/>
                        <ComboBox x:Name="CboMauThongKeChiTiet" Margin="12 0 3 6"/>
                    </StackPanel>
                </DockPanel>
            </TabItem>
            
            <TabItem x:Name="TabItemOperate" Header="Vận hành" Style="{StaticResource FlatRightTabItemStyle}" BorderBrush="DodgerBlue" Width="80" FontSize="14">
                <DockPanel Background="#fdfdfd">
                    <StackPanel Background="WhiteSmoke" Margin="3" DockPanel.Dock="Top">
                        <StackPanel x:Name="PnlOpSim" Background="WhiteSmoke" Margin="3">
                            <TextBlock Text="Mô phỏng" Margin="3" FontWeight="Bold"/>
                            <CheckBox x:Name="ChkSimEn" Content="Cho phép mô phỏng" Margin="9 0 3 3" Visibility="Collapsed"/>
                            <Button x:Name="BtSimulationSetPass" Content="Đổi pass" Margin="9 0 3 3" Width="90" HorizontalAlignment="Left" Style="{StaticResource BtnInfo}"
                                Click="BtSimulationSetPass_Click"/>
                        </StackPanel>
                        <TextBlock Text="Xe skip" Margin="3 0 3 3" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="9 0 3 3">
                            <TextBlock Text="TG DT0 - DT1: "/>
                            <TextBox x:Name="TxtXeSkipDT01" Width="90"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="9 0 3 3">
                            <TextBlock Text="TG DT1 - DT2: "/>
                            <TextBox x:Name="TxtXeSkipDT12" Width="90"/>
                        </StackPanel>
                        
                        <TextBlock Text="Debug" Margin="3 0 3 3" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="9 0 3 3">
                            <CheckBox x:Name="ChkShowDebug" Content="Hiển thị debug"/>
                        </StackPanel>
                        
                        <StackPanel>
                            <TextBlock Text="Chọn công thức khi chọn đơn hàng" Margin="3 0 3 3" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="9 0 3 3">
                                <CheckBox x:Name="ChkAutoCongThucDonHang" Content="Công thức sử dụng cuối cùng"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="PnlHack">
                            <TextBlock Text="Phiếu: Ghi đè m3" Margin="3 0 3 3" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="9 0 3 3">
                                <CheckBox x:Name="ChkPhieuAllowChangeM3" Content="Cho phép ghi đề m3 khi in phiếu"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </TabItem>

            <TabItem x:Name="TabItemSaveResults" Header="Chốt KL" Style="{StaticResource FlatRightTabItemStyle}" BorderBrush="DodgerBlue" Width="80" FontSize="14">
                <DockPanel Background="#fdfdfd">
                    <DockPanel Background="WhiteSmoke" Margin="3">
                        <TextBlock DockPanel.Dock="Top" Text="Tham số chốt khối lượng" Margin="3" FontWeight="Bold"/>
                        <StackPanel DockPanel.Dock="Right" Margin="3 0 0 3" HorizontalAlignment="Right">
                            <Button x:Name="BtTSChotKLAdd" Content="Thêm" Width="60" Click="BtTSChotKLAdd_Click"/>
                        </StackPanel>
                        <ListView ItemsSource="{Binding ChotKLSettings}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Tên cân">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBox Text="{Binding TenCan}" MinWidth="90"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Tham số">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBox Text="{Binding TenBien}" MinWidth="150"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Giá trị">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBox Text="{Binding GiaTri}" MinWidth="90"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </DockPanel>
            </TabItem>
            
            <TabItem x:Name="TabItemServer" Header="Server" Style="{StaticResource FlatRightTabItemStyle}" BorderBrush="DodgerBlue" Width="80" FontSize="14">
                <DockPanel Background="#fdfdfd">
                    <StackPanel Background="WhiteSmoke" Margin="3">
                        <TextBlock Text="Trạm" Margin="3" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="9 0 3 3">
                            <TextBlock Text="Tên trạm:" VerticalAlignment="Center" Width="120"/>
                            <TextBox x:Name="TxtTramId" Width="120"/>
                        </StackPanel>
                        <TextBlock Text="Địa chỉ server" Margin="3" FontWeight="Bold"/>
                        <DockPanel Margin="9 0 3 3">
                            <TextBlock Text="Địa chỉ IP:" VerticalAlignment="Center" Width="120"/>
                            <TextBox x:Name="TxtServerIP"/>
                        </DockPanel>
                        <DockPanel Margin="9 0 3 3">
                            <TextBlock Text="Tên CSDL:" VerticalAlignment="Center" Width="120"/>
                            <TextBox x:Name="TxtServerDb"/>
                        </DockPanel>
                        <DockPanel Margin="9 0 3 3">
                            <TextBlock Text="Username:" VerticalAlignment="Center" Width="120"/>
                            <TextBox x:Name="TxtServerUser"/>
                        </DockPanel>
                        <DockPanel Margin="9 0 3 3">
                            <TextBlock Text="Password:" VerticalAlignment="Center" Width="120"/>
                            <PasswordBox x:Name="txtServerPw"/>
                        </DockPanel>
                        <Button x:Name="BtTestServerConnection" Content="Thử kết nối" Margin="129 0 3 3" Width="90" HorizontalAlignment="Left" Style="{StaticResource BtnSuccess}"
                                Click="BtTestServerConnection_Click"/>
                    </StackPanel>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
