<Window x:Class="TronBeTongV3.View.WndCreateOrder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TronBeTongV3.View"
        xmlns:nmwpfctrl="clr-namespace:NMWPFControls.Controls;assembly=NMWPFControls"
        mc:Ignorable="d" SizeToContent="WidthAndHeight"
        Title="Tạo đơn trộn" Background="WhiteSmoke" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Colors.xaml"/>
                <ResourceDictionary Source="../Styles/BootstrapButtons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="3" Background="{StaticResource SCADABg04}" Margin="3">
            <StackPanel Margin="6">
                <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                    <TextBlock Text="Mã đơn hàng: " VerticalAlignment="Center" TextAlignment="Right" Width="90" FontWeight="Bold"/>
                    <TextBox Width="240" Padding="2 1" Text="{Binding DonHang.Ma}" Background="WhiteSmoke" IsReadOnly="True"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                    <TextBlock Text="Khách hàng: " VerticalAlignment="Center" TextAlignment="Right" Width="90" FontWeight="Bold"/>
                    <!--<ComboBox x:Name="CboKH" Width="240"
                              ItemsSource="{Binding DsKH}" DisplayMemberPath="Ten"
                              SelectionChanged="CboKH_SelectionChanged"
                              SelectedItem="{Binding DonHang.KhachHang}"/>-->
                    <nmwpfctrl:NMComboBoxV2 x:Name="CboKH" Width="240"
                              ZItemsSource="{Binding DsKH}" DisplayMemberPath="Ten"
                              ZSelectedChanged="CboKH_ZSelectedChanged">
                        <nmwpfctrl:NMComboBoxV2.ZListItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Ten}"/>
                            </DataTemplate>
                        </nmwpfctrl:NMComboBoxV2.ZListItemTemplate>
                    </nmwpfctrl:NMComboBoxV2>
                    <Button x:Name="BtEditKhachHang" Content="Thêm" Style="{StaticResource BtnInfo}" Height="20" Width="36" FontSize="10" Click="BtEditKhachHang_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                    <TextBlock Text="Dự án: " VerticalAlignment="Center" TextAlignment="Right" Width="90" FontWeight="Bold"/>
                    <nmwpfctrl:NMComboBoxV2 x:Name="CboDA" Width="240" ZItemsSource="{Binding DsDuAn}"
                                            ZSelectedChanged="CboDA_ZSelectedChanged" LostKeyboardFocus="CboDA_LostKeyboardFocus"
                                            ZText="{Binding DonHang.DuAn.DuAn}"/>
                    <Button x:Name="BtEditDuAn" Content="Thêm" Style="{StaticResource BtnInfo}" Height="20" Width="36" FontSize="10" Click="BtEditDuAn_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                    <TextBlock Text="Công trình: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                    <nmwpfctrl:NMComboBoxV2 x:Name="CboCT" Width="240" ZItemsSource="{Binding DsCongTrinh}"
                                            ZSelectedChanged="CboCT_ZSelectedChanged" LostKeyboardFocus="CboCT_LostKeyboardFocus"
                                            ZText="{Binding DonHang.DuAn.CongTrinh}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                    <TextBlock Text="Hạng mục: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                    <nmwpfctrl:NMComboBoxV2 x:Name="CboHM" Width="240" ZItemsSource="{Binding DsHangMuc}"
                                            ZSelectedChanged="CboHM_ZSelectedChanged" LostKeyboardFocus="CboHM_LostKeyboardFocus"
                                            ZText="{Binding DonHang.DuAn.HangMuc}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                    <TextBlock Text="Địa chỉ: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                    <TextBox x:Name="TxtDiaChi" Width="240" Padding="2 1"
                             Text="{Binding DonHang.DuAn.DiaChi}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                    <TextBlock Text="M3 Đơn hàng: " VerticalAlignment="Center" TextAlignment="Right" Width="90" FontWeight="Bold"/>
                    <TextBox x:Name="TxtM3DH" Width="120" Padding="2 1"
                             Text="{Binding DonHang.TheTichDH}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtSave" Content="Tạo mới" Width="90" Style="{StaticResource BtnSuccess}" Margin="0 0 36 0"
                            Click="BtSave_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</Window>
