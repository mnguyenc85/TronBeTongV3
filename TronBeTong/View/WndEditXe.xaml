<Window x:Class="TronBeTongV3.View.WndEditXe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TronBeTongV3.View"
        xmlns:nmwpfctrl="clr-namespace:NMWPFControls.Controls;assembly=NMWPFControls"
        mc:Ignorable="d"
        Title="Thông tin xe" Height="640" Width="900" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Colors.xaml"/>
                <ResourceDictionary Source="../Styles/BootstrapButtons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding AppZoom}" ScaleY="{Binding AppZoom}"/>
        </Grid.LayoutTransform>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="3"/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>
        <GridSplitter Grid.Column="1"/>

        <Border BorderThickness="1" BorderBrush="Gray" CornerRadius="3" Background="{StaticResource SCADABg04}" Margin="3 3 0 3">
            <DockPanel Margin="3">
                <TextBox x:Name="TxtFilter" DockPanel.Dock="Top" Padding="2 1"
                         TextChanged="TxtFilter_TextChanged"/>
                <ListView x:Name="LvXe" ItemsSource="{Binding Ds.CVDsXLx}" SelectionChanged="LvXe_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="STT" DisplayMemberBinding="{Binding STT}"/>
                            <GridViewColumn Header="Biển số xe" DisplayMemberBinding="{Binding Xe.BSX}"/>
                            <GridViewColumn Header="Tên lái xe" DisplayMemberBinding="{Binding LaiXe.Ten}"/>
                            <GridViewColumn Header="SĐT" DisplayMemberBinding="{Binding LaiXe.Sdt}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" BorderThickness="1" BorderBrush="Gray" CornerRadius="3" Background="{StaticResource SCADABg04}" Margin="0 3 3 3">
            <StackPanel Grid.Column="2" Margin="3">
                <TextBlock x:Name="LblXeTitle" FontWeight="Bold" Foreground="SteelBlue"/>
                <TextBlock Text="* Biển số xe:"/>
                <!--<TextBox Padding="2 1" Text="{Binding CurXe.BSX}"/>-->
                <nmwpfctrl:NMComboBoxV2 x:Name="CboXe" ZText="{Binding CurXe.BSX}" DisplayMemberPath="BSX"
                                      ZItemsSource="{Binding DsXe}" ZSelectedChanged="CboXe_ZSelectedChanged">
                    <nmwpfctrl:NMComboBoxV2.ZListItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding BSX}"/>
                        </DataTemplate>
                    </nmwpfctrl:NMComboBoxV2.ZListItemTemplate>
                </nmwpfctrl:NMComboBoxV2>
                <StackPanel Visibility="Collapsed">
                    <TextBlock Text="Dung tích:" Margin="0 3 0 0"/>
                    <TextBox x:Name="TxtDungTich" Padding="2 1" Text="{Binding CurXe.DungTich}"/>
                    <TextBlock Text="Dung tích tối thiểu:" Margin="0 3 0 0"/>
                    <TextBox Padding="2 1" Text="{Binding CurXe.DungTichMin}"/>
                </StackPanel>
                <Button x:Name="BtTruckNew" Content="Xe mới" Style="{StaticResource BtnPrimary}" Width="72" Margin="0 3 0 0" HorizontalAlignment="Right"
                        Click="BtNew_Click"/>
                <Separator Margin="0 3 0 2"/>

                <TextBlock x:Name="LblLaiXeTitle" FontWeight="Bold" Foreground="SteelBlue"/>
                <TextBlock Text="Tên lái xe:" Margin="0 3 0 0"/>
                <!--<TextBox Padding="2 1" Text="{Binding CurLX.Ten}"/>-->
                <nmwpfctrl:NMComboBoxV2 x:Name="CboLaiXe" ZText="{Binding CurLX.Ten}" DisplayMemberPath="Ten"
                                      ZItemsSource="{Binding DsLaiXe}" ZSelectedChanged="CboLaiXe_ZSelectedChanged">
                    <nmwpfctrl:NMComboBoxV2.ZListItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Ten}"/>
                        </DataTemplate>
                    </nmwpfctrl:NMComboBoxV2.ZListItemTemplate>
                </nmwpfctrl:NMComboBoxV2>
                <TextBlock Text="Điện thoại:" Margin="0 3 0 0"/>
                <TextBox x:Name="TxtSdt" Padding="2 1" Text="{Binding CurLX.Sdt}"/>
                <Button x:Name="BtDriverNew" Content="Lái Xe mới" Style="{StaticResource BtnPrimary}" Width="72" Margin="0 3 0 0" HorizontalAlignment="Right"
                        Click="BtNew_Click"/>
                <Separator Margin="0 3 0 2"/>

                <StackPanel Orientation="Horizontal" Margin="0 6 0 0" HorizontalAlignment="Right">
                    <Button x:Name="BtNew" Content="Mới" Style="{StaticResource BtnPrimary}" Width="72"
                            Click="BtNew_Click"/>
                    <Button Content="Lưu" Style="{StaticResource BtnSuccess}" Width="72" Margin="6 0 0 0"
                        Command="{Binding CmdSave}"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</Window>
