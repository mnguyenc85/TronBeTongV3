<UserControl x:Class="TronBeTongV3.View.ViewDonHang"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TronBeTongV3.View"
             xmlns:nmwpfctrl="clr-namespace:NMWPFControls.Controls;assembly=NMWPFControls"
             mc:Ignorable="d" Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Colors.xaml"/>
                <ResourceDictionary Source="../Styles/BootstrapButtons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid x:Name="PnlMain">
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="3" Background="{StaticResource SCADABg04}">
            <StackPanel Margin="3">
                <DockPanel Margin="0 0 0 6">
                    <TextBlock Text="Mã đơn hàng: " VerticalAlignment="Center" TextAlignment="Right" Width="90" FontWeight="Bold"/>
                    <TextBox MinWidth="90" Padding="2 1" IsReadOnly="True" Text="{Binding DonHang.Ma}" Background="WhiteSmoke" Focusable="False"/>
                </DockPanel>
                <DockPanel Margin="0 0 0 6">
                    <TextBlock Text="Khách hàng: " VerticalAlignment="Center" TextAlignment="Right" Width="90" FontWeight="Bold"/>
                    <TextBox MinWidth="90" Padding="2 1" IsReadOnly="True" Text="{Binding DonHang.KhachHang.Ten}" Background="WhiteSmoke" Focusable="False"/>
                </DockPanel>
                <DockPanel Margin="0 0 0 3">
                    <TextBlock Text="Dự án: " VerticalAlignment="Center" TextAlignment="Right" Width="90" FontWeight="Bold"/>
                    <TextBox MinWidth="90" Padding="2 1" IsReadOnly="True" Text="{Binding DonHang.DuAn.DuAn}" Background="WhiteSmoke" Focusable="False"/>
                </DockPanel>
                <DockPanel Margin="0 0 0 3">
                    <TextBlock Text="Công trình: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                    <TextBox MinWidth="90" Padding="2 1" IsReadOnly="True" Text="{Binding DonHang.DuAn.CongTrinh}" Background="WhiteSmoke" Focusable="False"/>
                </DockPanel>
                <DockPanel Margin="0 0 0 6">
                    <TextBlock Text="Hạng mục: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                    <TextBox MinWidth="90" Padding="2 1" IsReadOnly="True" Text="{Binding DonHang.DuAn.HangMuc}" Background="WhiteSmoke" Focusable="False"/>
                </DockPanel>
                <DockPanel Margin="0 0 0 6">
                    <TextBlock Text="M3 đơn hàng: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                    <TextBox MinWidth="90" Padding="2 1" IsReadOnly="True" Text="{Binding DonHang.TheTichDH}" Background="WhiteSmoke" Focusable="False"/>
                </DockPanel>
                <Separator Margin="0 0 0 6"/>

                <!--<StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                    <TextBlock Text="Số phiếu: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                    <TextBox x:Name="TxtSoPhieu" Width="90" Padding="2 1" Text="0" IsReadOnly="True" Background="WhiteSmoke" Focusable="False"/>
                </StackPanel>-->
                <DockPanel Margin="0 0 0 3">
                    <TextBlock Text="Xe: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                    <nmwpfctrl:NMComboBoxV2 x:Name="CboXe"
                                                ZItemsSource="{Binding DsXe}" DisplayMemberPath="BSX"
                                                ZSelectedChanged="CboXe_ZSelectedChanged">
                        <nmwpfctrl:NMComboBoxV2.ZListItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding BSX}"/>
                            </DataTemplate>
                        </nmwpfctrl:NMComboBoxV2.ZListItemTemplate>
                    </nmwpfctrl:NMComboBoxV2>
                </DockPanel>
                <DockPanel Margin="0 0 0 6">
                    <TextBlock Text="Lái xe: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                    <nmwpfctrl:NMComboBoxV2 x:Name="CboLaiXe"
                                                ZItemsSource="{Binding DsLaiXe}" DisplayMemberPath="Ten"
                                                ZSelectedChanged="CboLaiXe_ZSelectedChanged">
                        <nmwpfctrl:NMComboBoxV2.ZListItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Ten}"/>
                            </DataTemplate>
                        </nmwpfctrl:NMComboBoxV2.ZListItemTemplate>
                    </nmwpfctrl:NMComboBoxV2>
                </DockPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 0 6" Visibility="Collapsed">
                    <Button x:Name="BtOpenEditXe" Content="Sửa" Width="48" Style="{StaticResource BtnInfo}" Click="BtOpenEditXe_Click"/>
                    <Button x:Name="BtSaveXe" Content="Lưu" Width="48" Style="{StaticResource BtnSuccess}" Click="BtSaveXe_Click" Margin="3 0 0 0"/>
                </StackPanel>
                
                <DockPanel Margin="0 0 0 3">
                    <TextBlock Text="Công thức: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                    <nmwpfctrl:NMComboBoxV2 x:Name="CboCongThuc"
                                                ZItemsSource="{Binding DsCongThuc}" DisplayMemberPath="Ma"
                                                ZSelectedChanged="CboCongThuc_ZSelectedChanged">
                        <nmwpfctrl:NMComboBoxV2.ZListItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Ma}"/>
                            </DataTemplate>
                        </nmwpfctrl:NMComboBoxV2.ZListItemTemplate>
                    </nmwpfctrl:NMComboBoxV2>
                </DockPanel>
                <CheckBox x:Name="CboCanPGRieng" Content="Cân PG riêng" Margin="90 0 0 3" IsChecked="{Binding Phieu.CanPGNgoai}"
                          Checked="CboCanPGRieng_Checked" Unchecked="CboCanPGRieng_Unchecked"/>
                <TextBlock x:Name="LblCongThucLoi1" Text="Lỗi: Cấp phối không phù hợp cấu hình silo. (Nhấn chuột để sửa)" Foreground="Red" Margin="90 0 0 6" TextWrapping="Wrap"
                           MouseLeftButtonDown="LblCongThucLoi1_MouseLeftButtonDown" Visibility="Collapsed"/>

                <StackPanel Orientation="Horizontal" Margin="0 0 0 3">
                    <TextBlock Text="M3 trộn: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                    <nmwpfctrl:TextBoxDouble x:Name="TxtM3" Width="90" Padding="2 1" Text="0"
                                             ValueChanged="TxtM3_ValueChanged"
                                             PreviewKeyDown="TxtM3_PreviewKeyDown"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0 0 0 3">
                    <TextBlock Text="Số mẻ: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                    <nmwpfctrl:TextBoxDouble x:Name="TxtSoMe" Width="90" Padding="2 1" Text="0"
                                          ValueChanged="TxtSoMe_ValueChanged"
                                          PreviewKeyDown="TxtSoMe_PreviewKeyDown"/>
                    <Button x:Name="BtAutoCalSoMe" Content="Tự động tính" Margin="3 0 0 0" Style="{StaticResource BtnPrimary}"
                                Visibility="Collapsed"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                    <TextBlock Text="M3/mẻ: " VerticalAlignment="Center" TextAlignment="Right" Width="90"/>
                    <TextBox x:Name="TxtM3OverMe" Width="90" Padding="2 1" IsReadOnly="True" Text="{Binding Phieu.TheTichMe}" Background="WhiteSmoke" Focusable="False"
                             TextChanged="TxtM3OverMe_TextChanged"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
