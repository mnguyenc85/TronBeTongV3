<UserControl x:Class="TronBeTongV3.View.CtrlWICalibration"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TronBeTongV3.View"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/BootstrapButtons.xaml"/>
                <ResourceDictionary Source="../Styles/Colors.xaml"/>
                <ResourceDictionary Source="../Styles/FlatGroupBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <GroupBox Margin="2" Style="{StaticResource FlatGroupBoxStyle01}" Background="{StaticResource SCADABg04}" BorderBrush="Gray">
            <GroupBox.Header>
                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="2" Background="{StaticResource SCADABg04}">
                    <TextBlock Text="{Binding ZTitle}" FontWeight="Bold" Margin="2 1"/>
                </Border>
            </GroupBox.Header>
            <StackPanel Margin="12 6">
                <StackPanel Margin="6" Orientation="Horizontal">
                    <TextBlock Text="Chanel AI" Width="96" VerticalAlignment="Center" FontSize="14"/>
                    <Border BorderBrush="Gray" BorderThickness="1" Background="White" Width="108">
                        <TextBlock x:Name="txtChanelAI" Text="0" TextAlignment="Center" FontSize="20"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="6 0 6 6" Orientation="Horizontal">
                    <TextBlock Text="Mass" Width="96" VerticalAlignment="Center" FontSize="14"/>
                    <Border BorderBrush="Gray" BorderThickness="1" Background="White" Width="108">
                        <TextBlock x:Name="txtMass" Text="0" TextAlignment="Center" FontSize="20"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="6 0 6 6" Orientation="Horizontal">
                    <TextBlock Text="Zero" Width="96" VerticalAlignment="Center" FontSize="14"/>
                    <TextBox x:Name="txtZero" FontSize="20" TextAlignment="Center" Width="108"/>
                </StackPanel>

                <StackPanel Margin="6 0 6 6" Orientation="Horizontal">
                    <TextBlock Text="Span" Width="96" VerticalAlignment="Center" FontSize="14"/>
                    <TextBox x:Name="txtSpan" FontSize="20" TextAlignment="Center" Width="108"/>
                </StackPanel>

                <StackPanel Margin="6 0 6 6" Orientation="Horizontal">
                    <TextBlock Text="Set Mass" Width="96" VerticalAlignment="Center" FontSize="14"/>
                    <TextBox x:Name="txtSetMass" FontSize="20" TextAlignment="Center" Width="108"/>
                </StackPanel>

                <DockPanel Margin="6">
                    <Button x:Name="BtSetZero" Content="SET ZERO" Width="96" Style="{StaticResource BtnPrimary}" FontSize="16"
                            Click="BtSetZero_Click"/>
                    <Button x:Name="BtSetSpan" Content="SET SPAN" HorizontalAlignment="Right" Width="96" Style="{StaticResource BtnPrimary}" FontSize="16"
                            Click="BtSetSpan_Click"/>
                </DockPanel>
            </StackPanel>
        </GroupBox>
    </Grid>
</UserControl>
