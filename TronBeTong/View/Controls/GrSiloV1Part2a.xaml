<UserControl x:Class="TronBeTongV3.View.GrSiloV1Part2a"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TronBeTongV3.View"
             xmlns:ncmwpfctrl="clr-namespace:NMWPFControls.Controls;assembly=NMWPFControls"
             mc:Ignorable="d">
    <StackPanel>
        <local:BlendImageCtrl x:Name="ImgSep" ZSource="../../Images/silo03_b1.png" Height="6"/>
        <Grid Margin="0 -1 0 0">
            <local:BlendImageCtrl x:Name="ImgBody" ZSource="../../Images/silo03_b2.png"/>
            <ncmwpfctrl:TextBoxDouble x:Name="TxtInput" Margin="6 3" Padding="1 0" TextAlignment="Center" Text="{Binding ZText}"/>
        </Grid>
    </StackPanel>
</UserControl>
