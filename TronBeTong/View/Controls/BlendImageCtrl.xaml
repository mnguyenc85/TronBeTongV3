<UserControl x:Class="TronBeTongV3.View.BlendImageCtrl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TronBeTongV3.View"
             mc:Ignorable="d">
    <Grid x:Name="PnlMain">
        <Image Source="{Binding ZSource}" Stretch="Fill"/>
        <Rectangle x:Name="RectSep" Fill="{Binding ZBlend}">
            <Rectangle.OpacityMask>
                <ImageBrush ImageSource="{Binding ZSource}"/>
            </Rectangle.OpacityMask>
        </Rectangle>
    </Grid>
</UserControl>
