<Window x:Class="TronBeTongV3.View.WndEditDuAn"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TronBeTongV3.View"
        xmlns:nmwpfctrl="clr-namespace:NMWPFControls.Controls;assembly=NMWPFControls"
        mc:Ignorable="d"
        Title="Dự án" Height="640" Width="900" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Colors.xaml"/>
                <ResourceDictionary Source="../Styles/BootstrapButtons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding AppZoom}" ScaleY="{Binding AppZoom}"/>
        </Grid.LayoutTransform>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="3"/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>
        <GridSplitter Grid.Column="1"/>
        
        <Border BorderThickness="1" BorderBrush="Gray" CornerRadius="3" Background="{StaticResource SCADABg04}" Margin="3 3 0 3">
            <DockPanel Margin="3">
                <TextBox x:Name="TxtFilter" DockPanel.Dock="Top" Padding="2 1"
                         TextChanged="TxtFilter_TextChanged"/>
                <DataGrid x:Name="GrdDuAn" IsReadOnly="True" HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray"
                              AutoGenerateColumns="False" SelectionChanged="GrdDuAn_SelectionChanged"
                              ItemsSource="{Binding Ds.CVDsDA}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Binding="{Binding STT}"/>
                        <DataGridTextColumn Header="Dự án" Binding="{Binding DuAn}"/>
                        <DataGridTextColumn Header="Công trình" Binding="{Binding CongTrinh}"/>
                        <DataGridTextColumn Header="Hạng Mục" Binding="{Binding HangMuc}"/>
                        <DataGridTextColumn Header="Địa chỉ" Binding="{Binding DiaChi}"/>
                        <DataGridTextColumn Header="Khách hàng" Binding="{Binding KHMa}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" BorderThickness="1" BorderBrush="Gray" CornerRadius="3" Background="{StaticResource SCADABg04}" Margin="0 3 3 3">
            <StackPanel Grid.Column="2" Margin="3">
                <TextBlock x:Name="LblDATitle" FontWeight="Bold" Foreground="SteelBlue" FontSize="14"/>
                
                <TextBlock Text="* Dự án:"/>
                <ComboBox x:Name="CboTenDuAn" IsEditable="True" Padding="2 1" Text="{Binding CurDA.DuAn}" ItemsSource="{Binding Ds.CVStrDuAn}" DisplayMemberPath="VanBan"
                          SelectedValuePath="VanBan"/>
                
                <TextBlock Text="Công trình:" Margin="0 3 0 0"/>
                <ComboBox x:Name="CboTenCongTrinh" IsEditable="True" Padding="2 1" Text="{Binding CurDA.CongTrinh}" ItemsSource="{Binding Ds.CVStrCongTrinh}" DisplayMemberPath="VanBan"/>
                
                <TextBlock Text="Hạng mục:" Margin="0 3 0 0"/>
                <ComboBox x:Name="CboTenHangMuc" IsEditable="True" Padding="2 1" Text="{Binding CurDA.HangMuc}" ItemsSource="{Binding Ds.CVStrHangMuc}" DisplayMemberPath="VanBan"/>

                <TextBlock Text="Địa chỉ:" Margin="0 3 0 0"/>
                <ComboBox x:Name="CboTenDiaChi" IsEditable="True" Padding="2 1" Text="{Binding CurDA.DiaChi}" ItemsSource="{Binding Ds.CVStrDiaChi}" DisplayMemberPath="VanBan"/>

                <TextBlock Text="Khách hàng:" Margin="0 3 0 0"/>
                <nmwpfctrl:NMComboBoxV2 x:Name="CboKH" DisplayMemberPath="Ten"
                    ZItemsSource="{Binding DsKH}"
                    ZSelectedChanged="CboKH_ZSelectedChanged">
                    <nmwpfctrl:NMComboBoxV2.ZListItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Ten}"/>
                        </DataTemplate>
                    </nmwpfctrl:NMComboBoxV2.ZListItemTemplate>
                </nmwpfctrl:NMComboBoxV2>
                <TextBlock Text="Ghi chú:" Margin="0 3 0 0"/>
                <TextBox Padding="2 1" Height="48" Text="{Binding CurDA.GhiChu}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 6 0 0">
                    <Button x:Name="BtClone" Content="Bản sao" Style="{StaticResource BtnPrimary}" Width="72"
                            Click="BtClone_Click"/>
                    <Button x:Name="BtNew" Content="Mới" Style="{StaticResource BtnPrimary}" Width="72" Margin="6 0 0 0"
                            Click="BtNew_Click"/>
                    <Button Content="Lưu" Style="{StaticResource BtnSuccess}" Width="72" Margin="6 0 0 0"
                            Command="{Binding CmdSave}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 6 0 0">
                    <Button x:Name="BtImportCsv" Content="Import .csv" Style="{StaticResource BtnInfo}" Width="72"
                            Click="BtImportCsv_Click"/>
                    <Button x:Name="BtExportCsv" Content="Export .csv" Style="{StaticResource BtnInfo}" Width="72" Margin="6 0 0 0"
                            Click="BtExportCsv_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
