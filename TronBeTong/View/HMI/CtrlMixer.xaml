<UserControl x:Class="TronBeTongV3.View.CtrlMixer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TronBeTongV3.View"
             xmlns:nmwpfctrl="clr-namespace:NMWPFControls.Controls;assembly=NMWPFControls"
             mc:Ignorable="d">
    <StackPanel x:Name="PnlMain">
        <Grid>
            <Image Source="../../Images/mixer01_base.png"/>
            <Canvas>
                <Image Source="../../Images/mixer01_hand.png" Canvas.Left="82" Canvas.Top="38">
                    <Image.RenderTransform>
                        <RotateTransform Angle="{Binding HandAngle}" CenterX="36" CenterY="38"/>
                    </Image.RenderTransform>
                </Image>
                <Image Source="../../Images/mixer01_hand.png" Canvas.Left="160" Canvas.Top="38">
                    <Image.RenderTransform>
                        <RotateTransform Angle="{Binding HandAngle}" CenterX="36" CenterY="38"/>
                    </Image.RenderTransform>
                </Image>
            </Canvas>

            <Label x:Name="LblTGTron" Content="0/0s" Margin="40 4 0 0" VerticalAlignment="Top" Background="WhiteSmoke"
                   Padding="3 1" BorderBrush="Gray" BorderThickness="1" Width="90" HorizontalContentAlignment="Center" FontSize="18"/>
            <StackPanel Margin="0 0 0 26" VerticalAlignment="Bottom" Orientation="Horizontal">
                <Label x:Name="LblTGXaNua" Content="0/0s" Margin="90 0 0 0" VerticalAlignment="Bottom" Background="WhiteSmoke"                   
                   Padding="2 1" BorderBrush="Gray" BorderThickness="1" Width="66" HorizontalContentAlignment="Center" FontSize="18"/>
                <Label x:Name="LblTGXa" Content="0/0s" VerticalAlignment="Bottom" Background="WhiteSmoke"
                   Padding="2 1" BorderBrush="Gray" BorderThickness="1" Width="66" HorizontalContentAlignment="Center" FontSize="18"/>
            </StackPanel>

            <Label x:Name="LblMeCan" Content="0/0" FontSize="18"
                   Background="WhiteSmoke" BorderBrush="Gray" BorderThickness="1" 
                   Padding="2 1" Margin="0 -16 -30 0"
                   VerticalContentAlignment="Top" HorizontalAlignment="Right" HorizontalContentAlignment="Center"
                   Width="60" Height="28" ToolTip="Mẻ cân"/>

            <local:CtrlMultiStateButton x:Name="BtXaBeTong" Width="24" Height="24" VerticalAlignment="Bottom"
                                        ZText="V" ZActiveFill="Lime" Margin="225 0 0 0"
                                        ZStateChanged="CtrlMultiStateButton_ZStateChanged"/>

            <local:CtrlMultiStateButton x:Name="BtMotor" Width="32" Height="32" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                        ZText="M" ZActiveFill="Lime" Margin="0 0 0 24"
                                        ZStateChanged="BtMotor_ZStateChanged" ZMaxState="2"/>

            <StackPanel Margin="68 0 0 0" VerticalAlignment="Bottom" Orientation="Horizontal">
                <nmwpfctrl:CtrlLEDIndicator x:Name="LEDDCT" Height="24" ToolTip="Đóng" OnColor="LimeGreen"/>
                <nmwpfctrl:CtrlLEDIndicator x:Name="LEDMCTHalf" Height="24" ToolTip="Mở 1/2" Margin="49 0 0 0" OnColor="LimeGreen"/>
                <nmwpfctrl:CtrlLEDIndicator x:Name="LEDMCT" Height="24" ToolTip="Mở" Margin="30 0 0 0" OnColor="LimeGreen"/>
            </StackPanel>
        </Grid>
        <local:GrArrowDown x:Name="Arrow2" Width="36" Height="24" Margin="40 3 0 0"/>
    </StackPanel>
</UserControl>
