<UserControl x:Class="TronBeTongV3.View.CtrlTPXiMang"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TronBeTongV3.View"
             mc:Ignorable="d">
    <StackPanel>
        <StackPanel x:Name="PnlSilos" Orientation="Horizontal">
            <local:CtrlSilo02 Width="80" FontSize="16" ZFill="#80dfdf00"/>
            <local:CtrlSilo02 Width="80" FontSize="16" ZFill="#80dfdf00"/>
            <local:CtrlSilo02 Width="80" FontSize="16" ZFill="#80dfdf00"/>
            <local:CtrlSilo02 Width="80" FontSize="16" ZFill="#80dfdf00"/>
            <local:CtrlSilo02 Width="80" FontSize="16" ZFill="#80dfdf00" Visibility="Collapsed"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <local:CtrlWeightScale x:Name="WSCements1" ZFill="#80dfdf00" HorizontalAlignment="Center" Margin="20 10 20 0" Width="120"/>
            <local:CtrlWeightScale x:Name="WSCements2" ZFill="#80dfdf00" HorizontalAlignment="Center" Margin="20 10 20 0" Width="120"/>
        </StackPanel>
    </StackPanel>
</UserControl>
