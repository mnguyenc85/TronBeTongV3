<UserControl x:Class="TronBeTongV3.View.CtrlTPCotLieu2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TronBeTongV3.View"
             mc:Ignorable="d">
    <Canvas>
        <!--<local:GrCtrlXeSkip x:Name="GrXeSkip" Canvas.Left="160" Canvas.Top="90"/>-->
        <StackPanel>
            <StackPanel x:Name="PnlSilos" Orientation="Horizontal">
                <local:CtrlBin01 x:Name="Silo1" ZFill="#a04040ff" FontSize="14" ZHasVib="False" Margin="9 0"/>
                <local:CtrlBin01 x:Name="Silo2" ZFill="#a04040ff" FontSize="14" ZHasVib="False" Margin="9 0"/>
                <local:CtrlBin01 x:Name="Silo3" ZFill="#a04040ff" FontSize="14" ZHasVib="False" Margin="9 0"/>
                <local:CtrlBin01 x:Name="Silo4" ZFill="#a04040ff" FontSize="14" ZHasVib="False" Margin="9 0" Visibility="Collapsed"/>
                <local:CtrlBin01 x:Name="Silo5" ZFill="#a04040ff" FontSize="14" ZHasVib="False" Margin="9 0" Visibility="Collapsed"/>
                <local:CtrlBin01 x:Name="Silo6" ZFill="#a04040ff" FontSize="14" ZHasVib="False" Margin="9 0" Visibility="Collapsed"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <local:CtrlWeightScale x:Name="WsTotalCL1" ZFill="#a04040ff" Width="108" Margin="3 0"/>
                <local:CtrlWeightScale x:Name="WsTotalCL2" ZFill="#a04040ff" Width="108" Margin="3 0"
                                   Visibility="Collapsed"/>
                <local:CtrlWeightScale x:Name="WsTotalCL3" ZFill="#a04040ff" Width="108" Margin="3 0"
                                   Visibility="Collapsed"/>
                <local:CtrlWeightScale x:Name="WsTotalCL4" ZFill="#a04040ff"
                                   Width="108" Visibility="Collapsed"/>
            </StackPanel>
        </StackPanel>
    </Canvas>
</UserControl>
