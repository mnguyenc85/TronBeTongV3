<UserControl x:Class="TronBeTongV3.View.CtrlSilo01"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TronBeTongV3.View"
             mc:Ignorable="d" Width="72">
    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem x:Name="CmnConfig" Header="Cấu hình..." Click="CmnConfig_Click"/>
        </ContextMenu>
    </UserControl.ContextMenu>
    <Grid x:Name="PnlMain">
        <StackPanel>
            <TextBlock Text="{Binding ZTitle}" Foreground="White"/>
            <local:GrSiloV1Part2 x:Name="SiloPart1" ZText="0" FontSize="14" IsReadonly="True"/>
            <local:GrSiloV1Part2 x:Name="SiloPart2" ZText="0" FontSize="14" IsReadonly="True" FontWeight="Bold"/>
            <local:GrSiloV1Part2 x:Name="SiloPart3" ZText="0" FontSize="14" IsReadonly="True" ZForeground="Red" FontWeight="Bold"/>
            <Grid>
                <StackPanel>
                    <local:BlendImageCtrl x:Name="ImgRect1" ZSource="../../Images/silo03_c.png"/>

                    <local:CtrlMultiStateButton x:Name="BtValve" HorizontalAlignment="Center" Width="22" Height="22"
                                                ZText="V" ZActiveFill="LimeGreen" ToolTip="Van xả"
                                                ZStateChanged="BtValve_ZStateChanged"/>
                    <local:GrArrowDown x:Name="LEDArrow" HorizontalAlignment="Center" Height="16" Width="24" FontSize="10"
                                     Foreground="White"/>
                </StackPanel>
                <local:CtrlMultiStateButton x:Name="BtVib" HorizontalAlignment="Left" VerticalAlignment="Top" Width="22" Height="22"
                                            ZText="Vib" ZMaxState="2" FontSize="10" ZActiveFill="YellowGreen"
                                            Visibility="Collapsed"/>
                <TextBlock x:Name="LblMe" HorizontalAlignment="Right" VerticalAlignment="Center" Text="0/0"
                           Foreground="White" Visibility="Collapsed"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
