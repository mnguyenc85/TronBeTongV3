<UserControl x:Class="TronBeTongV3.View.CtrlMidBin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TronBeTongV3.View"
             xmlns:nmwpfctrl="clr-namespace:NMWPFControls.Controls;assembly=NMWPFControls"
             mc:Ignorable="d">
    <Grid>
        <StackPanel x:Name="PnlMain" HorizontalAlignment="Left">
            <Label x:Name="LblLenCLTG" Content="0/0s" VerticalAlignment="Bottom" Background="WhiteSmoke"
                   Padding="2 0" BorderBrush="Gray" BorderThickness="1" Width="72" HorizontalContentAlignment="Center" FontSize="16" ToolTip="TG lên CL TG"/>
            <Grid Height="60" Width="108">
                <local:BlendImageCtrl x:Name="Img1" ZSource="../../Images/weighted_bin2.png"/>
                <StackPanel Margin="3 1 3 21">
                    <nmwpfctrl:CtrlLEDIndicator x:Name="Led1" Height="16" Title="Open" Margin="42 0 0 0" ToolTip="Báo mở CLTG"/>
                    <nmwpfctrl:CtrlLEDIndicator x:Name="LedClose" Height="16" Title="Close" Margin="42 3 0 0" ToolTip="Báo đóng CLTG"/>
                </StackPanel>
            </Grid>
            <local:GrArrowDown x:Name="Arrow1" HorizontalAlignment="Center" Margin="0 3 0 0" Foreground="White" FontSize="10" Width="24" Height="16"/>
        </StackPanel>
        <StackPanel Margin="0 64 72 0">
            <local:CtrlMultiStateButton x:Name="BtOn1" Width="22" Height="22" ZText="V" ZMaxState="2"
                                                    ZActiveFill="LimeGreen"/>
        </StackPanel>
        <Label x:Name="LblTreMoXaCLTG" Content="0/0s" VerticalAlignment="Top" Background="WhiteSmoke" Margin="108 20 0 0"
                   Padding="2 0" BorderBrush="Gray" BorderThickness="1" Width="72" HorizontalContentAlignment="Center" FontSize="16" ToolTip="TG trễ mở xả CL TG"/>
    </Grid>
</UserControl>
