<UserControl x:Class="TronBeTongV3.View.CtrlMultiStateButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TronBeTongV3.View"
             mc:Ignorable="d" 
             d:DesignHeight="22" d:DesignWidth="22" IsEnabledChanged="UserControl_IsEnabledChanged">
    <UserControl.Resources>
        <RadialGradientBrush x:Key="BtnGlowBrush" GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.475" RadiusY="0.5">
            <RadialGradientBrush.GradientStops>
                <GradientStop Color="#d0ffffff" Offset="0" />
                <GradientStop Color="#00ffffff" Offset="1" />
            </RadialGradientBrush.GradientStops>
        </RadialGradientBrush>
    </UserControl.Resources>
    <Grid x:Name="PnlMain">
        <Border x:Name="BdrBtn" BorderBrush="Gray" BorderThickness="1" CornerRadius="16"
                Background="WhiteSmoke"
                MouseDown="Border_MouseDown" MouseUp="Border_MouseUp"
                MouseEnter="BdrBtn_MouseEnter" MouseLeave="BdrBtn_MouseLeave"
                Focusable="True" GotFocus="BdrBtn_GotFocus" LostFocus="BdrBtn_LostFocus"
                KeyDown="BdrBtn_KeyDown">
            <Grid>
                <TextBlock x:Name="LblTitle" Text="{Binding ZText}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Ellipse x:Name="rectGlow" Visibility="Hidden" Fill="{StaticResource BtnGlowBrush}"/>
                <Ellipse x:Name="rectFocus" Visibility="Hidden" Margin="1" Stroke="Black" StrokeThickness="1" StrokeDashArray="3 2"/>
            </Grid>
        </Border>
        <StackPanel x:Name="PnlState" HorizontalAlignment="Left" Margin="-8 0 0 0">
            <Ellipse x:Name="LED1" Fill="Gray" Width="6" Height="6" Margin="0 3 0 0"/>
            <Ellipse x:Name="LED2" Fill="Gray" Width="6" Height="6" Margin="0 4 0 0"/>
        </StackPanel>
    </Grid>
</UserControl>
