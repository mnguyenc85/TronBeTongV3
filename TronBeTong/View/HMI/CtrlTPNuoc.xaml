<UserControl x:Class="TronBeTongV3.View.CtrlTPNuoc"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TronBeTongV3.View"
             xmlns:ncmwpfctrl="clr-namespace:NMWPFControls.Controls;assembly=NMWPFControls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Styles/Colors.xaml"/>
                <ResourceDictionary Source="../../Styles/BootstrapButtons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <StackPanel>
            <local:CtrlWaterSilo x:Name="SiloWater" ZFill="#802060ff" ZTitle="Nước" FontSize="16"
                             ButtonClicked="SiloWater_ButtonClicked"/>
            <local:CtrlWeightScale x:Name="WSWater" ZFill="#802060ff" HorizontalAlignment="Center" Margin="0 10 0 0"
                               Width="120"
                               ButtonClicked="WSWater_ButtonClicked"/>
        </StackPanel>

        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="3" VerticalAlignment="Top" Margin="80 20 0 0"
                Background="{StaticResource SCADABg03}">
            <StackPanel Margin="3">
                <TextBlock Text="Thêm bớt nước"/>
                <ncmwpfctrl:TextBoxDouble x:Name="TxtAddWater" Value="0" Margin="0 0 0 12" ValueChanged="TxtAddWater_ValueChanged"/>

                <ncmwpfctrl:CtrlLEDIndicator x:Name="LEDWashMixer" Title="Rửa cối trộn" Height="16" Margin="0 0 0 3"/>
                <Button x:Name="BtStartWash" Content="Chạy" Style="{StaticResource BtnPrimary}" Margin="0 0 0 3"
                        Click="BtStartWash_Click"/>
                <Button x:Name="BtStopWash" Content="Dừng" Style="{StaticResource BtnDanger}"
                        Click="BtStopWash_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
