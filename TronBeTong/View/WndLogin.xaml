<Window x:Class="TronBeTongV3.View.WndLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TronBeTongV3.View"
        mc:Ignorable="d"
        Title="Đăng nhập" Width="270" SizeToContent="Height"
        FontSize="16" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown" Loaded="Window_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/BootstrapButtons.xaml"/>
                <ResourceDictionary Source="../Styles/Colors.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DropShadowEffect x:Key="ShadowEffect"
                  Color="Black"
                  Direction="270"
                  ShadowDepth="0"
                  Opacity="0.5"
                  BlurRadius="20"/>
        </ResourceDictionary>
    </Window.Resources>
    <Border Background="{StaticResource SCADABg04}" BorderBrush="Gray" BorderThickness="1" CornerRadius="3" Effect="{DynamicResource ShadowEffect}" Margin="20">
        <StackPanel>
            <Grid x:Name="PnlTitle" Background="Transparent" MouseDown="PnlTitle_MouseDown">
                <TextBlock Text="Đăng nhập" FontSize="24" Margin="6"/>
                <Button x:Name="BtClose" Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Width="24" Style="{StaticResource BtnSemiTransparent}" Click="BtClose_Click"/>
            </Grid>

            <StackPanel Margin="6">
                <TextBlock Text="Tài khoản" Foreground="#e333"/>
                <TextBox x:Name="TxtUser" Padding="2 1" TextChanged="TxtUser_TextChanged"/>
                <TextBlock Text="Mật mã" Foreground="#e333"/>
                <PasswordBox x:Name="TxtPW" Padding="2 1" PasswordChanged="TxtPassword_PasswordChanged"
                             KeyDown="TxtPW_KeyDown"/>
                <TextBlock x:Name="LblErrUser" Text="Tài khoản không hợp lệ" Foreground="Red" Visibility="Collapsed" FontSize="14"/>
                <TextBlock x:Name="LblErrPW" Text="Mật mã không hợp lệ" Foreground="Red" Visibility="Collapsed" FontSize="14"/>

                <DockPanel Margin="1 6 1 0">
                    <Button x:Name="BtLogin" Content="Đăng nhập" Width="90" DockPanel.Dock="Right" Style="{StaticResource BtnPrimary}" FontSize="16"
                            Click="BtLogin_Click"/>
                    <Button x:Name="BtTest" Content="Bỏ qua" Width="90" Style="{StaticResource BtnWarning}" FontSize="16"
                            Click="BtTest_Click"/>
                    <StackPanel/>
                </DockPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
