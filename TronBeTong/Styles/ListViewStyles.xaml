<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Style x:Key="ListViewItemStyle1" TargetType="ListViewItem">
        <!-- Set default background to Transparent -->
        <Setter Property="Background" Value="Transparent" />

        <Style.Triggers>
            <!-- Apply color to odd rows (AlternationIndex = 1) -->
            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                <Setter Property="Background" Value="#FFF0F0F0" />
            </Trigger>

            <!-- Hover effect (MouseOver) -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FFCCE5FF"/>
            </Trigger>

            <!-- Optional: selected state -->
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#803399FF"/>
                <!--<Setter Property="Foreground" Value="White"/>-->
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>