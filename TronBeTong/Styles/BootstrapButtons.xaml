    <SolidColorBrush x:Key="InfoActiveBgBrush">#31b0d5</SolidColorBrush>
    <SolidColorBrush x:Key="InfoActiveBorderBrush">#269abc</SolidColorBrush>

    <SolidColorBrush x:Key="WarningBgBrush">#f0ad4e</SolidColorBrush>
