    <SolidColorBrush x:Key="SuccessActiveBgBrush">#449d44</SolidColorBrush>
    <SolidColorBrush x:Key="SuccessActiveBorderBrush">#398439</SolidColorBrush>

    <SolidColorBrush x:Key="InfoBgBrush">#5bc0de</SolidColorBrush>
